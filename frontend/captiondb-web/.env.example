# ============================================================
# CaptionDB Frontend — Environment Variables
# ============================================================
# Copy this to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# Backend API base URL (must end without a trailing slash)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_BASE_URL=https://captiondb.onrender.com/api/v1

# API request timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT=10000

# App version (used in metadata and logs)
NEXT_PUBLIC_APP_VERSION=0.1.0
