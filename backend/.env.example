# ==============================================================
# CaptionDB Configuration
# ==============================================================
# This file provides environment variables that override default
# configurations in the application.
# Nested settings use a double underscore '__' to map to sub-models.
# ==============================================================

# --- Application ---
APP__NAME="CaptionDB"
APP__ENVIRONMENT="development"
# APP__VERSION="0.1.0"

# --- API ---
API__V1_PREFIX="/api/v1"
API__HOST="0.0.0.0"
API__PORT=8000

# --- Logging ---
LOGGING__LEVEL="DEBUG"
LOGGING__FORMAT="json"

# --- Security ---
SECURITY__SECRET_KEY="YOUR_SUPER_SECRET_KEY_HERE"

# --- CORS ---
# In production, specify actual frontend domains instead of '*'
CORS__ALLOWED_ORIGINS='["*"]'

# --- Storage ---
STORAGE__PROVIDER="local"
STORAGE__LOCAL_STORAGE_PATH="/tmp/captiondb_storage"

# --- AI Provider ---
AI__PROVIDER="gemini"
AI__API_KEY="YOUR_GEMINI_API_KEY_HERE"
AI__DEFAULT_MODEL="gemini-flash-lite-latest"

# --- Processing Limits ---
PROCESSING__MAX_VIDEO_SIZE_MB=500
PROCESSING__MAX_DURATION_SECONDS=3600

# --- Feature Flags ---
FEATURES__ENABLE_OCR=false
FEATURES__ENABLE_MEMORY=false
FEATURES__ENABLE_JUDGE=false

# --- Admin Console ---
# Generate hash: python -c "import hashlib,secrets; s=secrets.token_hex(16); print(f'pbkdf2_sha256$100000${s}${hashlib.pbkdf2_hmac(\"sha256\", b\"YOUR_PASSWORD\", bytes.fromhex(s), 100000).hex()}')"
ADMIN__EMAIL="mikkhokher@gmail.com"
ADMIN__PASSWORD_HASH="pbkdf2_sha256$100000$SALT_HEX$HASH_HEX"
ADMIN__TOKEN_EXPIRE_MINUTES=720
